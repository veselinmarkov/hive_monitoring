
upstream app_server {
    # fail_timeout=0 means we always retry an upstream even if it failed
    # to return a good HTTP response

                # TCP configuration: Gunicorn will bind to 127.0.0.1:8000 inside the container
                server 127.0.0.1:8000 fail_timeout=0;
                # If you prefer a UNIX socket, change the startup script and uncomment below:
                # server unix:/tmp/gunicorn.sock fail_timeout=0;
  }

server {
       listen 80;
       
       server_name bee-comfort.com;

        root /var/www/hivebox;
        index index.html;

        location / {
                root /var/www/hivebox;
                set $fallback_file /index.html;
                if ($http_accept !~ text/html) {
                        set $fallback_file /null;
                }
                try_files $uri $fallback_file;
        }

       location /api/ {
               proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
                proxy_set_header X-Forwarded-Proto $scheme;
                proxy_set_header Host $http_host;
                # we don't want nginx trying to do something clever with
                # redirects, we set the Host: header above already.
                proxy_redirect off;
                proxy_pass http://app_server;
        #include         uwsgi_params;
        #uwsgi_pass      unix:/tmp/gunicorn.sock;
       }
}
